{
  "name": "envtypes",
  "version": "0.1.0",
  "description": "Type-safe environment variables. Scan your code, generate schemas, validate .env files.",
  "type": "module",
  "bin": {
    "envtypes": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "env",
    "environment",
    "variables",
    "type-safe",
    "typescript",
    "validation",
    "dotenv",
    "schema"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ts-morph": "^27.0.2",
    "typescript": "^6.0.2"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "vitest": "^4.1.4"
  }
}
